SECRET_KEY=
POSTGRES_DB=lamto
POSTGRES_USER=lamto_writer
POSTGRES_PASSWORD=lamto-writer
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_SERVICE_ROLE=lamto_service
POSTGRES_APPLICATION_ROLE=lamto_app
# Migrations/tests override POSTGRES_USER/POSTGRES_PASSWORD with lamto_owner.
# lamto_app is the restricted general role; signed service transitions use the
# dedicated executor role configured below on the transaction-bearing connection.
POSTGRES_EXECUTOR_ROLE=lamto_writer
EVIDENCE_WRITE_SECRET=
PRIVATE_STORAGE_ENDPOINT_URL=http://127.0.0.1:9000
PRIVATE_STORAGE_BUCKET=lamto-documents
PRIVATE_STORAGE_ACCESS_KEY=lamto-local
PRIVATE_STORAGE_SECRET_KEY=lamto-local-secret
CLAMAV_HOST=127.0.0.1
CLAMAV_PORT=3310
AI_TRIAGE_URL=
AI_TRIAGE_TOKEN=

# Blockchain / evidence anchoring (Besu QBFT)
BLOCKCHAIN_CHAIN_ID=1337
PLATFORM_SIGNER_PRIVATE_KEY=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d
BLOCKCHAIN_RPC_URL=http://127.0.0.1:8545
EVIDENCE_CONTRACT_ADDRESS=
BLOCKCHAIN_RELAYER_PRIVATE_KEY=
BLOCKCHAIN_CONTRACT_OWNER_PRIVATE_KEY=
# Anchoring transport: besu (default) | disabled.
# disabled settles evidence locally (LOCAL_SIGNED) — never presented as chain-confirmed.
# EVIDENCE_ANCHORING_BACKEND=besu
# Optional override; default resolves to chain/out/EvidenceRegistry.sol/EvidenceRegistry.json
# EVIDENCE_REGISTRY_ABI_PATH=

# Push notifications (FCM). Leave FIREBASE_CREDENTIALS empty to keep push off.
FIREBASE_CREDENTIALS=
PUSH_ENABLED=
PUSH_DAILY_CAP_PER_CATEGORY=10

# --- Gate recognition ---
GATE_EVENT_RETENTION_HOURS=24
GATE_ENROLLMENT_PHOTO_TTL_HOURS=72
GATE_CREDENTIAL_ROTATION_GRACE_HOURS=24
GATE_RECOGNITION_THROTTLE_SECONDS=1
# Unvalidated pilot starting point. Set the calibrated value before any pilot.
GATE_FACE_MATCH_THRESHOLD=0.38
GATE_MIN_FACE_SHARPNESS=40
GATE_EMBEDDING_KEY=
# Bake the buffalo_l model pack into the deployment image; do not download at runtime.
INSIGHTFACE_HOME=/opt/insightface
